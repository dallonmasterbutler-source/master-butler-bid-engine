# had no indexes and silently priced without them)
data/*
!data/assessor/
data/assessor/*
!data/assessor/*.json.gz
__pycache__/
.DS_Store
.env
*.json.secret
client_secret*.json
.env.backup
data/pricing_overrides.json
reports/
